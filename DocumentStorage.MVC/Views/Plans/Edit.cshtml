@model DocumentStorage.MVC.Models.Plan.UpdatePlanModel

@{
    ViewData["Title"] = "Edit Plan";
}

<h1>Edit Plan</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Code" class="form-label"></label>
                <input asp-for="Code" class="form-control" />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Currency" class="form-label"></label>
                <select asp-for="Currency" class="form-control">
                    <option value="USD">USD</option>
                    <option value="EUR">EUR</option>
                    <option value="GBP">GBP</option>
                    <option value="RON">RON</option>
                </select>
                <span asp-validation-for="Currency" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="BillingCycle" class="form-label"></label>
                <select asp-for="BillingCycle" class="form-control">
                    <option value="Monthly">Monthly</option>
                    <option value="Quarterly">Quarterly</option>
                    <option value="Yearly">Yearly</option>
                </select>
                <span asp-validation-for="BillingCycle" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SortOrder" class="form-label"></label>
                <input asp-for="SortOrder" class="form-control" />
                <span asp-validation-for="SortOrder" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>

            <hr />
            <h4>Plan Limits</h4>

            <div class="mb-3">
                <label asp-for="StorageLimitGB" class="form-label"></label>
                <input asp-for="StorageLimitGB" class="form-control" type="number" step="0.1" min="0.1" />
                <span asp-validation-for="StorageLimitGB" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DocumentLimit" class="form-label"></label>
                <input asp-for="DocumentLimit" class="form-control" type="number" min="0" />
                <span asp-validation-for="DocumentLimit" class="text-danger"></span>
                <small class="form-text text-muted">Set to 0 for unlimited documents</small>
            </div>

            <div class="mb-3">
                <label asp-for="MaxFileSizeMB" class="form-label"></label>
                <input asp-for="MaxFileSizeMB" class="form-control" type="number" min="1" />
                <span asp-validation-for="MaxFileSizeMB" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}