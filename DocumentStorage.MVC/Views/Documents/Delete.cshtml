@model DocumentStorage.MVC.Models.Document.DocumentModel

@{
    ViewData["Title"] = "Delete Document";
}

<h1>Delete Document</h1>

<div class="alert alert-warning">
    <h3>Are you sure you want to delete this document?</h3>
    <p>This action will mark the document as deleted and it will no longer be accessible.</p>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.FileName)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.FileName)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.FormattedSize)</dt>
            <dd class="col-sm-9">@Model.FormattedSize</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ContentType)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ContentType)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.AccountName)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.AccountName)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CreatedAt)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.CreatedAt)</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    @if (ViewBag.CanDelete == true)
    {
        <button type="submit" class="btn btn-danger">Delete</button>
    }
    else
    {
        <button type="button" class="btn btn-danger" disabled>Cannot Delete</button>
    }
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>