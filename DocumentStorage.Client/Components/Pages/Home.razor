@page "/"

<PageTitle>Home - Document Storage</PageTitle>

<div class="bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <!-- Hero Section -->
        <div class="text-center">
            <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl md:text-6xl">
                <span class="block">Secure Document</span>
                <span class="block text-blue-600">Storage System</span>
            </h1>
            <p class="mt-3 max-w-md mx-auto text-base text-gray-500 sm:text-lg md:mt-5 md:text-xl md:max-w-3xl">
                Store, manage, and access your documents securely from anywhere. Built with modern technology for reliability and speed.
            </p>
            <div class="mt-5 max-w-md mx-auto sm:flex sm:justify-center md:mt-8">
                <div class="rounded-md shadow">
                    <a href="/documents" class="w-full flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 md:py-4 md:text-lg md:px-10">
                        Get Started
                    </a>
                </div>
            </div>
        </div>

        <!-- Features Section -->
        <div class="mt-24">
            <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
                <div class="text-center">
                    <div class="flex justify-center">
                        <div class="flex items-center justify-center h-12 w-12 rounded-md bg-blue-500 text-white">
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                            </svg>
                        </div>
                    </div>
                    <h3 class="mt-4 text-lg font-medium text-gray-900">Easy Upload</h3>
                    <p class="mt-2 text-base text-gray-500">
                        Drag and drop or click to upload. Support for multiple file formats including PDF, Word, Excel, and images.
                    </p>
                </div>

                <div class="text-center">
                    <div class="flex justify-center">
                        <div class="flex items-center justify-center h-12 w-12 rounded-md bg-blue-500 text-white">
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                            </svg>
                        </div>
                    </div>
                    <h3 class="mt-4 text-lg font-medium text-gray-900">Secure Storage</h3>
                    <p class="mt-2 text-base text-gray-500">
                        Your documents are stored securely with enterprise-grade encryption and access controls.
                    </p>
                </div>

                <div class="text-center">
                    <div class="flex justify-center">
                        <div class="flex items-center justify-center h-12 w-12 rounded-md bg-blue-500 text-white">
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M13 10V3L4 14h7v7l9-11h-7z"/>
                            </svg>
                        </div>
                    </div>
                    <h3 class="mt-4 text-lg font-medium text-gray-900">Fast Access</h3>
                    <p class="mt-2 text-base text-gray-500">
                        Quick download and preview of your documents. Optimized for performance and reliability.
                    </p>
                </div>
            </div>
        </div>

        <!-- Stats Section -->
        <div class="mt-24 bg-gray-50 rounded-lg">
            <div class="max-w-7xl mx-auto py-12 px-4 sm:py-16 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">
                    <div class="text-center">
                        <p class="text-4xl font-bold text-blue-600">10MB</p>
                        <p class="mt-1 text-lg text-gray-500">Max File Size</p>
                    </div>
                    <div class="text-center">
                        <p class="text-4xl font-bold text-blue-600">Multiple</p>
                        <p class="mt-1 text-lg text-gray-500">File Formats</p>
                    </div>
                    <div class="text-center">
                        <p class="text-4xl font-bold text-blue-600">Secure</p>
                        <p class="mt-1 text-lg text-gray-500">Storage</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>