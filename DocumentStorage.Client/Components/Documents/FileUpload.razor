@using DocumentStorage.Client.Models
@using DocumentStorage.Client.Services
@using Microsoft.AspNetCore.Components.Forms

<div class="w-full">
    <div @ondragenter="HandleDragEnter"
         @ondragleave="HandleDragLeave"
         @ondragover="HandleDragOver"
         @ondragover:preventDefault="true"
         @ondrop="HandleDrop"
         @ondrop:preventDefault="true"
         class="@GetDropZoneClass()">

        <InputFile id="fileInput" OnChange="OnFileSelected" class="hidden" multiple="false" accept="@AcceptedFileTypes" />

        <label for="fileInput" class="cursor-pointer">
            <div class="flex flex-col items-center justify-center py-12">
                <svg class="w-12 h-12 mb-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                </svg>

                <p class="mb-2 text-sm text-gray-500">
                    <span class="font-semibold">Click to upload</span> or drag and drop
                </p>
                <p class="text-xs text-gray-400">PDF, DOC, DOCX, XLS, XLSX, PNG, JPG up to 10MB</p>
            </div>
        </label>
    </div>

    @if (IsUploading)
    {
        <div class="mt-4">
            <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-gray-700">Uploading...</span>
                <span class="text-sm text-gray-500">@UploadProgress%</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
                <div class="bg-blue-600 h-2 rounded-full transition-all duration-300" style="width: @(UploadProgress)%"></div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(Message))
    {
        <div class="@GetMessageClass() mt-4 px-4 py-3 rounded-lg">
            <p class="text-sm">@Message</p>
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback<DocumentDto> OnFileUploaded { get; set; }
    [Inject] private DocumentService DocumentService { get; set; } = default!;

    private bool IsDragging = false;
    private bool IsUploading = false;
    private int UploadProgress = 0;
    private string Message = string.Empty;
    private bool IsSuccess = false;

    private string AcceptedFileTypes = ".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg";

    private void HandleDragEnter()
    {
        IsDragging = true;
    }

    private void HandleDragLeave()
    {
        IsDragging = false;
    }

    private void HandleDragOver()
    {
        IsDragging = true;
    }

    private async Task HandleDrop(DragEventArgs e)
    {
        IsDragging = false;
        // Note: In Blazor Server, we can't directly access dropped files from DragEventArgs
        // File input is still the primary method
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file == null)
            return;

        if (file.Size > 10 * 1024 * 1024) // 10MB
        {
            Message = "File size exceeds 10MB limit.";
            IsSuccess = false;
            return;
        }

        await UploadFile(file);
    }

    private async Task UploadFile(IBrowserFile file)
    {
        IsUploading = true;
        UploadProgress = 0;
        Message = string.Empty;

        try
        {
            // Simulate progress (since we can't track actual upload progress easily)
            _ = SimulateProgress();

            var result = await DocumentService.UploadDocumentAsync(file);

            IsUploading = false;
            UploadProgress = 100;

            if (result.Success)
            {
                Message = result.Message ?? "File uploaded successfully!";
                IsSuccess = true;

                if (result.Document != null)
                {
                    await OnFileUploaded.InvokeAsync(result.Document);
                }

                // Clear message after 3 seconds
                _ = Task.Delay(3000).ContinueWith(_ =>
                {
                    Message = string.Empty;
                    InvokeAsync(StateHasChanged);
                });
            }
            else
            {
                Message = result.Message ?? "Upload failed. Please try again.";
                IsSuccess = false;
            }
        }
        catch (Exception ex)
        {
            IsUploading = false;
            Message = $"Error: {ex.Message}";
            IsSuccess = false;
        }
    }

    private async Task SimulateProgress()
    {
        while (IsUploading && UploadProgress < 90)
        {
            await Task.Delay(100);
            UploadProgress += Random.Shared.Next(5, 15);
            if (UploadProgress > 90) UploadProgress = 90;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string GetDropZoneClass()
    {
        var baseClass = "relative border-2 border-dashed rounded-lg transition-all duration-200 ";

        if (IsDragging)
            return baseClass + "border-blue-500 bg-blue-50";

        return baseClass + "border-gray-300 hover:border-gray-400";
    }

    private string GetMessageClass()
    {
        return IsSuccess
            ? "bg-green-100 border border-green-400 text-green-700"
            : "bg-red-100 border border-red-400 text-red-700";
    }
}