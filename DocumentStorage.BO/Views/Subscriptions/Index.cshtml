@model IEnumerable<DocumentStorage.BO.Models.Subscription.SubscriptionDto>

@{
    ViewData["Title"] = "Subscriptions";
}

<h1>Subscriptions Management</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Subscription</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.AccountType)</th>
            <th>@Html.DisplayNameFor(model => model.PlanName)</th>
            <th>@Html.DisplayNameFor(model => model.PlanCode)</th>
            <th>@Html.DisplayNameFor(model => model.Status)</th>
            <th>@Html.DisplayNameFor(model => model.PeriodStart)</th>
            <th>@Html.DisplayNameFor(model => model.PeriodEnd)</th>
            <th>@Html.DisplayNameFor(model => model.PlanPrice)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.AccountType)</td>
                <td>@Html.DisplayFor(modelItem => item.PlanName)</td>
                <td>@Html.DisplayFor(modelItem => item.PlanCode)</td>
                <td>
                    @if (item.Status == "Active")
                    {
                        <span class="badge bg-success">@item.Status</span>
                    }
                    else if (item.Status == "Cancelled")
                    {
                        <span class="badge bg-danger">@item.Status</span>
                    }
                    else if (item.Status == "Expired")
                    {
                        <span class="badge bg-warning">@item.Status</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@item.Status</span>
                    }
                </td>
                <td>@Html.DisplayFor(modelItem => item.PeriodStart)</td>
                <td>@Html.DisplayFor(modelItem => item.PeriodEnd)</td>
                <td>
                    @if (item.PlanPrice.HasValue)
                    {
                        @Html.DisplayFor(modelItem => item.PlanPrice) @Html.DisplayFor(modelItem => item.PlanCurrency)
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>