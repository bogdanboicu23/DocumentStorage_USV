@model DocumentStorage.BO.Models.Plan.PlanDto

@{
    ViewData["Title"] = "Delete Plan";
    var canDelete = ViewBag.CanDelete ?? true;
}

<h1>Delete Plan</h1>

<h3 class="text-danger">Are you sure you want to delete this plan?</h3>

@if (!canDelete)
{
    <div class="alert alert-warning" role="alert">
        <strong>Warning!</strong> This plan has active subscriptions and cannot be deleted.
    </div>
}

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Code)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Code)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Price)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Price) @Html.DisplayFor(model => model.Currency)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.BillingCycle)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.BillingCycle)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.IsActive)
        </dt>
        <dd class="col-sm-10">
            @if (Model.IsActive)
            {
                <span class="badge bg-success">Active</span>
            }
            else
            {
                <span class="badge bg-secondary">Inactive</span>
            }
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.SortOrder)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.SortOrder)
        </dd>
    </dl>

    @if (canDelete)
    {
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </form>
    }
    else
    {
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    }
</div>