@using DocumentStorage.Client.Models
@using DocumentStorage.Client.Services
@using Microsoft.JSInterop

<div class="w-full">
    @if (Documents == null)
    {
        <div class="flex justify-center items-center py-12">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600"></div>
        </div>
    }
    else if (Documents.Count == 0)
    {
        <div class="text-center py-12">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900">No documents</h3>
            <p class="mt-1 text-sm text-gray-500">Get started by uploading a document.</p>
        </div>
    }
    else
    {
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
            @foreach (var doc in Documents)
            {
                <div class="relative group bg-white rounded-lg border border-gray-200 hover:border-gray-300 hover:shadow-lg transition-all duration-200">
                    <div class="p-6">
                        <div class="flex items-start justify-between">
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center mb-2">
                                    @{
                                        var iconColor = GetFileIconColor(doc.FileType);
                                        var iconPath = GetFileIconPath(doc.FileType);
                                    }
                                    <svg class="h-8 w-8 @iconColor mr-3" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="@iconPath"/>
                                    </svg>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-gray-900 truncate" title="@doc.FileName">
                                            @doc.FileName
                                        </p>
                                        <p class="text-xs text-gray-500">
                                            @doc.DisplaySize
                                        </p>
                                    </div>
                                </div>

                                <p class="text-xs text-gray-400 mt-4">
                                    Uploaded @doc.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                                </p>
                            </div>
                        </div>

                        <div class="mt-4 flex space-x-2">
                            <button @onclick="() => DownloadDocument(doc)"
                                    class="flex-1 inline-flex justify-center items-center px-3 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                                <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"/>
                                </svg>
                                Download
                            </button>

                            <button @onclick="() => DeleteDocument(doc)"
                                    class="inline-flex justify-center items-center px-3 py-2 border border-red-300 text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (ShowDeleteConfirm)
    {
        <div class="fixed inset-0 z-50 overflow-y-auto">
            <div class="flex items-center justify-center min-h-screen px-4">
                <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity"></div>

                <div class="relative bg-white rounded-lg max-w-md w-full p-6 z-50">
                    <h3 class="text-lg font-medium text-gray-900 mb-4">Delete Document</h3>
                    <p class="text-sm text-gray-500 mb-6">
                        Are you sure you want to delete "@DocumentToDelete?.FileName"? This action cannot be undone.
                    </p>

                    <div class="flex justify-end space-x-3">
                        <button @onclick="CancelDelete"
                                class="px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
                            Cancel
                        </button>
                        <button @onclick="ConfirmDelete"
                                class="px-4 py-2 border border-transparent rounded-md text-sm font-medium text-white bg-red-600 hover:bg-red-700">
                            Delete
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public List<DocumentDto>? Documents { get; set; }
    [Parameter] public EventCallback<DocumentDto> OnDocumentDeleted { get; set; }
    [Inject] private DocumentService DocumentService { get; set; } = default!;
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;

    private bool ShowDeleteConfirm = false;
    private DocumentDto? DocumentToDelete = null;

    private async Task DownloadDocument(DocumentDto document)
    {
        try
        {
            Console.WriteLine($"Starting download for document: {document.FileName} (ID: {document.Id})");
            var fileBytes = await DocumentService.DownloadDocumentAsync(document.Id);

            if (fileBytes != null && fileBytes.Length > 0)
            {
                Console.WriteLine($"Received {fileBytes.Length} bytes for document {document.FileName}");
                var fileName = document.FileName;
                var contentType = document.ContentType ?? GetContentType(document.FileType);
                var base64 = Convert.ToBase64String(fileBytes);

                // Escape filename for JavaScript
                var escapedFileName = fileName.Replace("\\", "\\\\").Replace("'", "\\'").Replace("\"", "\\\"");

                // Create a data URL and trigger download
                var script = "(() => {" +
                    "const link = document.createElement('a');" +
                    $"link.href = 'data:{contentType};base64,{base64}';" +
                    $"link.download = '{escapedFileName}';" +
                    "link.style.display = 'none';" +
                    "document.body.appendChild(link);" +
                    "link.click();" +
                    "document.body.removeChild(link);" +
                    $"console.log('Download triggered for file: {escapedFileName}');" +
                    "})();";

                await JSRuntime.InvokeVoidAsync("eval", script);
                Console.WriteLine($"Download triggered for {document.FileName}");
            }
            else
            {
                Console.WriteLine($"No data received for document {document.FileName}. The file may not exist on the server.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error downloading document {document.FileName}: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
        }
    }

    private void DeleteDocument(DocumentDto document)
    {
        DocumentToDelete = document;
        ShowDeleteConfirm = true;
    }

    private async Task ConfirmDelete()
    {
        if (DocumentToDelete != null)
        {
            var success = await DocumentService.DeleteDocumentAsync(DocumentToDelete.Id);
            if (success)
            {
                await OnDocumentDeleted.InvokeAsync(DocumentToDelete);
            }
        }

        ShowDeleteConfirm = false;
        DocumentToDelete = null;
    }

    private void CancelDelete()
    {
        ShowDeleteConfirm = false;
        DocumentToDelete = null;
    }

    private string GetContentType(string? fileType)
    {
        return fileType?.ToLower() switch
        {
            "pdf" => "application/pdf",
            "doc" => "application/msword",
            "docx" => "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
            "xls" => "application/vnd.ms-excel",
            "xlsx" => "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            "png" => "image/png",
            "jpg" or "jpeg" => "image/jpeg",
            _ => "application/octet-stream"
        };
    }

    private string GetFileIconColor(string? fileType)
    {
        return fileType?.ToLower() switch
        {
            "pdf" => "text-red-500",
            "doc" or "docx" => "text-blue-500",
            "xls" or "xlsx" => "text-green-500",
            "png" or "jpg" or "jpeg" => "text-purple-500",
            _ => "text-gray-500"
        };
    }

    private string GetFileIconPath(string? fileType)
    {
        return fileType?.ToLower() switch
        {
            "pdf" or "doc" or "docx" => "M9 2a1 1 0 000 2h2a1 1 0 100-2H9z M4 5a2 2 0 012-2 1 1 0 000 2H6a2 2 0 00-2 2v6h16V7a2 2 0 00-2-2h-1a1 1 0 100-2 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5z",
            "xls" or "xlsx" => "M3 3v18h18V3H3zm16 16H5V5h14v14zM7 7h2v2H7V7zm0 4h2v2H7v-2zm0 4h2v2H7v-2zm4-8h6v2h-6V7zm0 4h6v2h-6v-2zm0 4h6v2h-6v-2z",
            "png" or "jpg" or "jpeg" => "M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z",
            _ => "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
        };
    }
}