@using Microsoft.AspNetCore.Components.Authorization
@using DocumentStorage.Client.Services.Auth
@implements IDisposable
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject AuthService AuthService


<div class="navbar bg-gradient-to-r from-purple-700 via-blue-700 to-cyan-700 text-white shadow-lg">
    <div class="container mx-auto flex justify-between items-center px-4 py-3">
        <!-- Logo/Brand -->
        <div class="flex items-center space-x-3">
            <div class="w-10 h-10 bg-white/20 rounded-lg flex items-center justify-center backdrop-blur">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
            </div>
            <a href="/" class="text-xl font-bold hover:text-white/90 transition-colors">
                Document Storage
            </a>
        </div>

        <!-- Desktop Navigation -->
        <nav class="hidden md:flex items-center space-x-1">
            <AuthorizeView>
                <Authorized>
                    <NavLink href="documents"
                             class="nav-item px-4 py-2 rounded-lg hover:bg-white/10 transition-all duration-200">
                        <span class="flex items-center space-x-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                            </svg>
                            <span>My Documents</span>
                        </span>
                    </NavLink>

                    <NavLink href="shared"
                             class="nav-item px-4 py-2 rounded-lg hover:bg-white/10 transition-all duration-200">
                        <span class="flex items-center space-x-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                            </svg>
                            <span>Shared</span>
                        </span>
                    </NavLink>

                    <NavLink href="plans"
                             class="nav-item px-4 py-2 rounded-lg hover:bg-white/10 transition-all duration-200">
                        <span class="flex items-center space-x-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            <span>Plans</span>
                        </span>
                    </NavLink>
                </Authorized>
                <NotAuthorized>
                    <NavLink href="/" Match="NavLinkMatch.All"
                             class="nav-item px-4 py-2 rounded-lg hover:bg-white/10 transition-all duration-200">
                        <span class="flex items-center space-x-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                            </svg>
                            <span>Home</span>
                        </span>
                    </NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </nav>

        <!-- User Section -->
        <div class="flex items-center space-x-3">
            <AuthorizeView>
                <Authorized>
                    <!-- User Avatar Dropdown -->
                    <div class="relative group">
                        <button class="flex items-center space-x-2 px-3 py-2 rounded-lg hover:bg-white/10 transition-all duration-200">
                            <div class="w-10 h-10 bg-gradient-to-br from-purple-400 to-blue-400 rounded-full flex items-center justify-center shadow-md">
                                <span class="text-white font-bold text-sm">
                                    @GetUserInitials(GetUserFullName(context))
                                </span>
                            </div>
                            <span class="hidden md:block text-white font-medium">@GetUserFullName(context)</span>
                            <svg class="w-4 h-4 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </button>

                        <!-- Dropdown Menu -->
                        <div class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-xl py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                            <a href="/profile" class="block px-4 py-2 text-gray-700 hover:bg-gray-100 transition-colors">
                                <span class="flex items-center space-x-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                    </svg>
                                    <span>Profile</span>
                                </span>
                            </a>
                            <a href="/plans" class="block px-4 py-2 text-gray-700 hover:bg-gray-100 transition-colors">
                                <span class="flex items-center space-x-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                    <span>Plans & Billing</span>
                                </span>
                            </a>
                            <a href="/settings" class="block px-4 py-2 text-gray-700 hover:bg-gray-100 transition-colors">
                                <span class="flex items-center space-x-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    </svg>
                                    <span>Settings</span>
                                </span>
                            </a>
                            <hr class="my-2">
                            <button @onclick="HandleLogout" class="w-full text-left px-4 py-2 text-red-600 hover:bg-red-50 transition-colors">
                                <span class="flex items-center space-x-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                                    </svg>
                                    <span>Sign Out</span>
                                </span>
                            </button>
                        </div>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <!-- Login Button -->
                    <a href="/login"
                       class="px-4 py-2 bg-white/20 backdrop-blur rounded-lg hover:bg-white/30 transition-all duration-200 flex items-center space-x-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
                        </svg>
                        <span>Sign In</span>
                    </a>

                    <!-- Register Button -->
                    <a href="/register"
                       class="ml-2 px-4 py-2 bg-white text-purple-700 font-semibold rounded-lg hover:bg-gray-100 transition-all duration-200 shadow-md">
                        Get Started
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <!-- Mobile Menu Toggle -->
        <button @onclick="ToggleMobileMenu" class="md:hidden text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
        </button>
    </div>

    <!-- Mobile Menu -->
    @if (showMobileMenu)
    {
        <div class="md:hidden absolute top-full left-0 w-full bg-white shadow-lg animate-slideDown">
            <nav class="px-4 py-3 space-y-1">
                <NavLink href="/" Match="NavLinkMatch.All"
                         class="block px-4 py-2 text-gray-700 hover:bg-gray-100 rounded-lg transition-colors"
                         @onclick="CloseMobileMenu">
                    Home
                </NavLink>

                <AuthorizeView>
                    <Authorized>
                        <NavLink href="documents"
                                 class="block px-4 py-2 text-gray-700 hover:bg-gray-100 rounded-lg transition-colors"
                                 @onclick="CloseMobileMenu">
                            Documents
                        </NavLink>

                        <hr class="my-2">

                        <button @onclick="HandleLogout"
                                class="w-full text-left px-4 py-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors">
                            Sign Out
                        </button>
                    </Authorized>
                    <NotAuthorized>
                        <NavLink href="login"
                                 class="block px-4 py-2 text-gray-700 hover:bg-gray-100 rounded-lg transition-colors"
                                 @onclick="CloseMobileMenu">
                            Sign In
                        </NavLink>
                        <NavLink href="register"
                                 class="block px-4 py-2 text-purple-700 font-semibold hover:bg-purple-50 rounded-lg transition-colors"
                                 @onclick="CloseMobileMenu">
                            Get Started
                        </NavLink>
                    </NotAuthorized>
                </AuthorizeView>
            </nav>
        </div>
    }
</div>

<style>
    .nav-item.active {
        background-color: rgba(255, 255, 255, 0.15);
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-slideDown {
        animation: slideDown 0.3s ease-out;
    }
</style>

@code {
    private bool showMobileMenu = false;
    private bool isAuthenticated = false;
    private string userName = "User";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        UpdateAuthenticationState(authState);

        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
    }

    private async void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        var authState = await task;
        UpdateAuthenticationState(authState);
        await InvokeAsync(StateHasChanged);
    }

    private void UpdateAuthenticationState(AuthenticationState authState)
    {
        isAuthenticated = authState.User?.Identity?.IsAuthenticated ?? false;
        if (isAuthenticated)
        {
            userName = GetUserFullName(authState);
            Console.WriteLine($"User authenticated: {userName}");
        }
        else
        {
            Console.WriteLine("User not authenticated");
        }
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
    }

    private void ToggleMobileMenu()
    {
        showMobileMenu = !showMobileMenu;
    }

    private void CloseMobileMenu()
    {
        showMobileMenu = false;
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: true);
    }

    private string GetUserFullName(AuthenticationState authState)
    {
        var user = authState.User;

        // Try to get the name claim (full name)
        var nameClaim = user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;
        if (!string.IsNullOrEmpty(nameClaim))
            return nameClaim;

        // Try to get GivenName and Surname
        var givenName = user.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? "";
        var surname = user.FindFirst(System.Security.Claims.ClaimTypes.Surname)?.Value ?? "";

        if (!string.IsNullOrEmpty(givenName) || !string.IsNullOrEmpty(surname))
            return $"{givenName} {surname}".Trim();

        // Fallback to email
        var email = user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
        if (!string.IsNullOrEmpty(email))
            return email.Split('@')[0]; // Return the part before @

        return "User";
    }

    private string GetUserInitials(string? name)
    {
        if (string.IsNullOrEmpty(name))
            return "U";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();

        return name[0].ToString().ToUpper();
    }
}