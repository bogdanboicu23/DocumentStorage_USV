@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

<AuthorizeView>
    <NotAuthorized>
        <!-- Floating Action Button for Non-Authenticated Users -->
        <div class="fixed bottom-8 right-8 z-50 group">
            <!-- Main Button -->
            <button @onclick="ToggleMenu"
                    class="w-16 h-16 bg-gradient-to-r from-purple-600 to-blue-600 rounded-full shadow-2xl flex items-center justify-center text-white transform transition-all duration-300 hover:scale-110 hover:rotate-12 group-hover:shadow-3xl">
                @if (isOpen)
                {
                    <svg class="w-8 h-8 transform rotate-45 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                }
                else
                {
                    <svg class="w-8 h-8 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                }
            </button>

            <!-- Floating Menu -->
            @if (isOpen)
            {
                <div class="absolute bottom-20 right-0 space-y-3 animate-fade-in-up">
                    <!-- Register Button -->
                    <a href="/register"
                       class="flex items-center justify-end group/item">
                        <span class="mr-3 px-4 py-2 bg-white text-gray-700 rounded-lg shadow-lg opacity-0 group-hover/item:opacity-100 transition-opacity whitespace-nowrap">
                            Create Account
                        </span>
                        <div class="w-12 h-12 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full shadow-lg flex items-center justify-center text-white transform transition-all duration-200 hover:scale-110">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                            </svg>
                        </div>
                    </a>

                    <!-- Login Button -->
                    <a href="/login"
                       class="flex items-center justify-end group/item">
                        <span class="mr-3 px-4 py-2 bg-white text-gray-700 rounded-lg shadow-lg opacity-0 group-hover/item:opacity-100 transition-opacity whitespace-nowrap">
                            Sign In
                        </span>
                        <div class="w-12 h-12 bg-gradient-to-r from-cyan-500 to-blue-500 rounded-full shadow-lg flex items-center justify-center text-white transform transition-all duration-200 hover:scale-110">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                            </svg>
                        </div>
                    </a>
                </div>
            }

            <!-- Backdrop -->
            @if (isOpen)
            {
                <div @onclick="CloseMenu" class="fixed inset-0 z-[-1]"></div>
            }
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    @@keyframes fade-in-up {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        animation: fade-in-up 0.3s ease-out forwards;
    }
</style>

@code {
    private bool isOpen = false;

    private void ToggleMenu()
    {
        isOpen = !isOpen;
    }

    private void CloseMenu()
    {
        isOpen = false;
    }
}