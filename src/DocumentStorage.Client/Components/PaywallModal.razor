@using DocumentStorage.Shared.DTOs.Plan
@using DocumentStorage.Shared.DTOs.Usage
@using Microsoft.Extensions.Logging
@using DocumentStorage.Client.Services.Auth
@inject IHttpClientFactory HttpClientFactory
@inject ServerAuthStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject ILogger<PaywallModal> Logger
@inject IConfiguration Configuration

@if (ShowUpgradeResult)
{
    <div class="result-dialog-backdrop" @onclick="() => ShowUpgradeResult = false">
        <div class="result-dialog @(IsUpgradeSuccess ? "success" : "error")" @onclick:stopPropagation="true">
            <div class="result-icon">
                @if (IsUpgradeSuccess)
                {
                    <svg class="success-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                }
                else
                {
                    <svg class="error-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                }
            </div>
            <h3 class="result-title">@UpgradeResultTitle</h3>
            <p class="result-message">@UpgradeResultMessage</p>
            <button class="result-button @(IsUpgradeSuccess ? "success-button" : "error-button")"
                    @onclick="() => ShowUpgradeResult = false">
                OK
            </button>
        </div>
    </div>
}

@if (IsVisible)
{
    <div class="modal-backdrop" @onclick="Close">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>@Title</h2>
                <button class="close-button" @onclick="Close">&times;</button>
            </div>

            <div class="modal-body">
                @if (!string.IsNullOrEmpty(Message))
                {
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i>
                        <span>@Message</span>
                    </div>
                }

                @if (CurrentUsage != null)
                {
                    <div class="usage-section">
                        <h3>Current Usage</h3>
                        <div class="usage-stats">
                            <div class="usage-item">
                                <label>Storage Used:</label>
                                <div class="progress-container">
                                    <div class="progress-bar" style="width: @(CurrentUsage.StoragePercentage)%"></div>
                                    <span class="progress-text">@FormatBytes(CurrentUsage.UsedStorageBytes) / @FormatBytes(CurrentUsage.MaxStorageBytes)</span>
                                </div>
                            </div>
                            @if (CurrentUsage.MaxDocuments > 0)
                            {
                                <div class="usage-item">
                                    <label>Documents:</label>
                                    <div class="progress-container">
                                        <div class="progress-bar" style="width: @(CurrentUsage.DocumentPercentage)%"></div>
                                        <span class="progress-text">@CurrentUsage.UsedDocuments / @CurrentUsage.MaxDocuments</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="plans-section">
                    <h3>Available Plans</h3>
                    @if (Plans == null)
                    {
                        <div class="loading">Loading plans...</div>
                    }
                    else if (Plans.Any())
                    {
                        <div class="plans-grid">
                            @foreach (var plan in Plans)
                            {
                                <div class="plan-card @(plan.IsPopular ? "popular" : "")">
                                    @if (plan.IsPopular)
                                    {
                                        <div class="popular-badge">Most Popular</div>
                                    }
                                    <h4>@plan.Name</h4>
                                    <div class="price">
                                        <span class="currency">@plan.Currency</span>
                                        <span class="amount">@plan.Price.ToString("0.00")</span>
                                        <span class="period">/@plan.BillingCycle</span>
                                    </div>
                                    <p class="description">@plan.Description</p>
                                    <ul class="features">
                                        @foreach (var feature in plan.Features)
                                        {
                                            <li><i class="fas fa-check"></i> @feature</li>
                                        }
                                    </ul>
                                    <div class="limits">
                                        <div class="limit-item">
                                            <i class="fas fa-hdd"></i>
                                            <span>@FormatBytes(plan.StorageLimitBytes) Storage</span>
                                        </div>
                                        @if (plan.DocumentLimit.HasValue && plan.DocumentLimit > 0)
                                        {
                                            <div class="limit-item">
                                                <i class="fas fa-file"></i>
                                                <span>@plan.DocumentLimit documents</span>
                                            </div>
                                        }
                                    </div>
                                    <button class="upgrade-button @(plan.IsPopular ? "primary" : "")"
                                            @onclick="() => UpgradeToPlan(plan.Id)"
                                            disabled="@IsUpgrading">
                                        <span>@(IsUpgrading ? "Processing..." : "Upgrade Now")</span>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p>No plans available at this time.</p>
                    }
                </div>
            </div>
        </div>
    </div>
}

<style>
    .modal-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(168, 85, 247, 0.1));
        backdrop-filter: blur(10px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-content {
        background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
        border-radius: 24px;
        max-width: 1200px;
        width: 90%;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(255, 255, 255, 0.5);
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px 32px;
        border-bottom: 1px solid rgba(99, 102, 241, 0.1);
        background: linear-gradient(135deg, rgba(99, 102, 241, 0.05), rgba(168, 85, 247, 0.05));
        border-radius: 24px 24px 0 0;
    }

    .modal-header h2 {
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .close-button {
        background: rgba(255, 255, 255, 0.8);
        border: 1px solid rgba(99, 102, 241, 0.2);
        border-radius: 12px;
        font-size: 24px;
        cursor: pointer;
        color: #6b7280;
        padding: 0;
        width: 40px;
        height: 40px;
        line-height: 1;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .close-button:hover {
        background: #6366f1;
        color: white;
        transform: scale(1.05);
    }

    .modal-body {
        padding: 30px;
    }

    .alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 25px;
    }

    .alert-warning {
        background: linear-gradient(135deg, #fef3c7 0%, #fed7aa 100%);
        border: 1px solid #f59e0b;
        color: #92400e;
        box-shadow: 0 4px 12px rgba(251, 191, 36, 0.15);
    }

    .usage-section {
        margin-bottom: 30px;
    }

    .usage-section h3 {
        font-size: 18px;
        margin-bottom: 15px;
        color: #333;
    }

    .usage-stats {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .usage-item {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .usage-item label {
        font-size: 14px;
        color: #666;
        font-weight: 500;
    }

    .progress-container {
        position: relative;
        background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
        border-radius: 12px;
        height: 32px;
        overflow: hidden;
        box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.06);
    }

    .progress-bar {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        background: linear-gradient(90deg, #6366f1, #a855f7);
        border-radius: 12px;
        transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 2px 8px rgba(99, 102, 241, 0.3);
    }

    .progress-text {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        font-size: 12px;
        font-weight: 500;
        color: #333;
        z-index: 1;
    }

    .plans-section h3 {
        font-size: 20px;
        margin-bottom: 20px;
        color: #333;
    }

    .plans-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
    }

    .plan-card {
        position: relative;
        background: linear-gradient(135deg, #ffffff 0%, #f9fafb 100%);
        border: 2px solid transparent;
        background-clip: padding-box;
        border-radius: 20px;
        padding: 28px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

    .plan-card::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 20px;
        padding: 2px;
        background: linear-gradient(135deg, #e5e7eb, #f3f4f6);
        z-index: -1;
    }

    .plan-card:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 12px 40px rgba(99, 102, 241, 0.15);
    }

    .plan-card:hover::before {
        background: linear-gradient(135deg, #6366f1, #a855f7);
    }

    .plan-card.popular {
        background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
        box-shadow: 0 8px 32px rgba(99, 102, 241, 0.2);
    }

    .plan-card.popular::before {
        background: linear-gradient(135deg, #6366f1, #a855f7);
    }

    .popular-badge {
        position: absolute;
        top: -14px;
        left: 50%;
        transform: translateX(-50%);
        background: linear-gradient(135deg, #6366f1, #a855f7);
        color: white;
        padding: 6px 20px;
        border-radius: 24px;
        font-size: 12px;
        font-weight: 600;
        white-space: nowrap;
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .plan-card h4 {
        margin: 0 0 15px 0;
        font-size: 22px;
        color: #333;
    }

    .price {
        display: flex;
        align-items: baseline;
        margin-bottom: 15px;
        font-weight: bold;
    }

    .currency {
        font-size: 18px;
        color: #666;
        margin-right: 4px;
    }

    .amount {
        font-size: 32px;
        color: #333;
    }

    .period {
        font-size: 16px;
        color: #666;
        margin-left: 4px;
    }

    .description {
        color: #666;
        margin-bottom: 20px;
        font-size: 14px;
        line-height: 1.5;
    }

    .features {
        list-style: none;
        padding: 0;
        margin: 0 0 20px 0;
    }

    .features li {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 0;
        font-size: 14px;
        color: #4b5563;
        transition: transform 0.2s ease;
    }

    .features li:hover {
        transform: translateX(4px);
        color: #6366f1;
    }

    .features i {
        color: #6366f1;
        font-size: 14px;
        background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(168, 85, 247, 0.1));
        padding: 4px;
        border-radius: 50%;
    }

    .limits {
        display: flex;
        gap: 20px;
        margin-bottom: 20px;
        padding: 15px;
        background: #f9f9f9;
        border-radius: 8px;
    }

    .limit-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        color: #555;
    }

    .limit-item i {
        color: #666;
    }

    .upgrade-button {
        width: 100%;
        padding: 14px 20px;
        border: none;
        border-radius: 12px;
        background: linear-gradient(135deg, #e5e7eb 0%, #f3f4f6 100%);
        color: #4b5563;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }

    .upgrade-button::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #6366f1, #a855f7);
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .upgrade-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(99, 102, 241, 0.25);
    }

    .upgrade-button:hover::before {
        opacity: 1;
    }

    .upgrade-button:hover span {
        color: white;
    }

    .upgrade-button.primary {
        background: linear-gradient(135deg, #6366f1, #a855f7);
        color: white;
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
    }

    .upgrade-button.primary:hover {
        box-shadow: 0 8px 24px rgba(99, 102, 241, 0.4);
        transform: translateY(-3px);
    }

    .upgrade-button span {
        position: relative;
        z-index: 1;
        transition: color 0.3s ease;
