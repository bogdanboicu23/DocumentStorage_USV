    .loading {
        text-align: center;
        padding: 40px;
        color: #666;
    }

    @@media (max-width: 768px) {
        .plans-grid {
            grid-template-columns: 1fr;
        }
    }

    /* Result Dialog Styles */
    .result-dialog-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(5px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2000;
        animation: fadeIn 0.2s ease;
    }

    .result-dialog {
        background: white;
        border-radius: 20px;
        padding: 32px;
        max-width: 400px;
        width: 90%;
        text-align: center;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        animation: slideUp 0.3s ease;
    }

    .result-dialog.success {
        background: linear-gradient(135deg, #ffffff 0%, #f0fdf4 100%);
        border: 2px solid #10b981;
    }

    .result-dialog.error {
        background: linear-gradient(135deg, #ffffff 0%, #fef2f2 100%);
        border: 2px solid #ef4444;
    }

    .result-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto 20px;
    }

    .success-icon {
        color: #10b981;
        animation: checkmark 0.5s ease;
    }

    .error-icon {
        color: #ef4444;
        animation: shake 0.5s ease;
    }

    .result-title {
        font-size: 24px;
        font-weight: 700;
        margin: 0 0 12px 0;
        color: #1f2937;
    }

    .result-message {
        font-size: 16px;
        color: #6b7280;
        margin: 0 0 24px 0;
        line-height: 1.5;
    }

    .result-button {
        padding: 12px 32px;
        border: none;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        min-width: 120px;
    }

    .success-button {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

    .success-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4);
    }

    .error-button {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: white;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
    }

    .error-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(239, 68, 68, 0.4);
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @@keyframes slideUp {
        from {
            transform: translateY(20px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    @@keyframes checkmark {
        0% { transform: scale(0) rotate(45deg); }
        50% { transform: scale(1.2) rotate(45deg); }
        100% { transform: scale(1) rotate(0deg); }
    }

    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
        20%, 40%, 60%, 80% { transform: translateX(5px); }
    }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public string Title { get; set; } = "Upgrade Your Plan";
    [Parameter] public string Message { get; set; } = "";
    [Parameter] public UsageDto? CurrentUsage { get; set; }
    [Parameter] public EventCallback<Guid> OnPlanSelected { get; set; }

    private List<PlanWithLimitsDto>? Plans { get; set; }
    private bool IsUpgrading { get; set; } = false;
    private string ApiBaseUrl => Configuration["ApiSettings:BaseUrl"] ?? "https://localhost:7150";

    // Upgrade result dialog
    private bool ShowUpgradeResult { get; set; } = false;
    private string UpgradeResultTitle { get; set; } = "";
    private string UpgradeResultMessage { get; set; } = "";
    private bool IsUpgradeSuccess { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        if (IsVisible)
        {
            await LoadPlans();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && Plans == null)
        {
            await LoadPlans();
        }
    }

    private async Task LoadPlans()
    {
        Logger.LogInformation("Loading plans from API");
        try
        {
            var httpClient = CreateAuthorizedHttpClient();
            var response = await httpClient.GetAsync("{ApiBaseUrl}/api/plans");
            if (response.IsSuccessStatusCode)
            {
                Plans = await response.Content.ReadFromJsonAsync<List<PlanWithLimitsDto>>();
                Logger.LogInformation($"Successfully loaded {Plans?.Count ?? 0} plans");
            }
            else
            {
                Logger.LogWarning($"Failed to load plans. Status: {response.StatusCode}, Reason: {response.ReasonPhrase}");
                Plans = new List<PlanWithLimitsDto>();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading plans from API");
            Plans = new List<PlanWithLimitsDto>();
        }
    }

    private async Task UpgradeToPlan(Guid planId)
    {
        IsUpgrading = true;
        Logger.LogInformation($"Attempting to upgrade to plan {planId}");

        try
        {
            var httpClient = CreateAuthorizedHttpClient();
            var response = await httpClient.PostAsync($"{ApiBaseUrl}/api/plans/upgrade/{planId}", null);

            if (response.IsSuccessStatusCode)
            {
                Logger.LogInformation($"Successfully upgraded to plan {planId}");
                await OnPlanSelected.InvokeAsync(planId);
                await Close();

                // Show success dialog instead of browser alert
                ShowUpgradeResult = true;
                UpgradeResultTitle = "✨ Upgrade Successful!";
                UpgradeResultMessage = "Your plan has been upgraded successfully. Your new limits are now active.";
                IsUpgradeSuccess = true;
                StateHasChanged();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Logger.LogWarning($"Failed to upgrade to plan {planId}. Status: {response.StatusCode}, Error: {error}");

                // Parse error message
                string errorMessage = "Unable to upgrade plan at this time.";
                if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                {
                    errorMessage = "Your session has expired. Please log in again.";
                }
                else if (!string.IsNullOrEmpty(error))
                {
                    try
                    {
                        var errorObj = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(error);
                        if (errorObj != null && errorObj.ContainsKey("message"))
                        {
                            errorMessage = errorObj["message"].ToString() ?? errorMessage;
                        }
                        else if (errorObj != null && errorObj.ContainsKey("error"))
                        {
                            errorMessage = errorObj["error"].ToString() ?? errorMessage;
                        }
                    }
                    catch
                    {
                        errorMessage = error.Length > 200 ? error.Substring(0, 200) + "..." : error;
                    }
                }

                // Show error dialog instead of browser alert
                ShowUpgradeResult = true;
                UpgradeResultTitle = "❌ Upgrade Failed";
                UpgradeResultMessage = errorMessage;
                IsUpgradeSuccess = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, $"Error upgrading to plan {planId}");

            // Show error dialog
            ShowUpgradeResult = true;
            UpgradeResultTitle = "❌ Error";
            UpgradeResultMessage = $"An unexpected error occurred: {ex.Message}";
            IsUpgradeSuccess = false;
            StateHasChanged();
        }
        finally
        {
            IsUpgrading = false;
        }
    }

    private async Task Close()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(false);
    }

    private string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        int order = 0;
        double size = bytes;
        while (size >= 1024 && order < sizes.Length - 1)
        {
            order++;
            size = size / 1024;
        }
        return $"{size:0.##} {sizes[order]}";
    }

    private HttpClient CreateAuthorizedHttpClient()
    {
        var httpClient = HttpClientFactory.CreateClient("AuthorizedClient");
        var token = AuthStateProvider.GetToken();
        if (!string.IsNullOrEmpty(token))
        {
            httpClient.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            Logger.LogInformation($"Authorization header set for API request with token starting: {token.Substring(0, Math.Min(10, token.Length))}...");
        }
        else
        {
            Logger.LogWarning("No authentication token available for API request");
        }
        return httpClient;
    }
}