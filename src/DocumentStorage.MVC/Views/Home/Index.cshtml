@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="row">
    <div class="col-lg-12">
        <h2>Dashboard</h2>
        <hr />
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-header bg-secondary text-white">
                Recent Activity
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Action</th>
                                <th>User</th>
                                <th>Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-muted">Loading...</td>
                                <td colspan="3">Activity data will be loaded from database</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-secondary text-white">
                System Status
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <ul class="list-unstyled">
                            <li class="mb-2"><strong>API Status:</strong> <span class="badge bg-success">Online</span></li>
                            <li class="mb-2"><strong>Database:</strong> <span class="badge bg-success">Connected</span></li>
                            <li class="mb-2"><strong>Cache:</strong> <span class="badge bg-success">Active</span></li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <ul class="list-unstyled">
                            <li class="mb-2"><strong>Environment:</strong> Development</li>
                            <li class="mb-2"><strong>Version:</strong> 1.0.0</li>
                            <li class="mb-2"><strong>Server Time:</strong> @DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header bg-dark text-white">
                Administration
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="/Plans" class="btn btn-outline-primary">Manage Plans</a>
                    <a href="/Subscriptions" class="btn btn-outline-primary">View Subscriptions</a>
                    <a href="/Documents" class="btn btn-outline-primary">Browse Documents</a>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header bg-dark text-white">
                External Links
            </div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    <li class="mb-2"><a href="http://localhost:5076" target="_blank">Client Application</a></li>
                    <li class="mb-2"><a href="https://localhost:7150/swagger" target="_blank">API Documentation</a></li>
                    <li><a href="/logs" class="text-muted">System Logs</a></li>
                </ul>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-dark text-white">
                Database Info
            </div>
            <div class="card-body">
                <small class="text-muted">
                    <strong>Connection:</strong> DocumentStorageDB<br/>
                    <strong>Provider:</strong> SQL Server<br/>
                    <strong>Migration:</strong> Up to date
                </small>
            </div>
        </div>
    </div>
</div>